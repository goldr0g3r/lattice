  "private": true,
  "description": "Reproducible governance scripts for the Lattice repo. Reads YAML config from .github/ and pushes it into GitHub via the `gh` CLI.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
